{
  "name": "pigrow-server",
  "version": "1.0.0",
  "description": "Indoor growing automation software",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node --env-file=.env --import tsx --test src/api/modules/**/*.test.ts",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "openapi:check": "tsx scripts/export-openapi.ts && git diff --exit-code openapi.json",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "type-check": "tsc --noEmit",
    "prepare": "lefthook install",
    "quality": "npm run lint && npm run format:check && npm run type-check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JacquesNolte/PiGrow-Server.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/JacquesNolte/PiGrow-Server/issues"
  },
  "homepage": "https://github.com/JacquesNolte/PiGrow-Server#readme",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sinclair/typebox": "^0.34.49",
    "fastify": "^5.8.5",
    "mqtt": "^5.15.1",
    "mqtt-match": "^3.0.0",
    "pg": "^8.21.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@prisma/config": "^7.8.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/socket.io": "^3.0.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
