generator client {
  provider        = "prisma-client"
  output          = "../src/generated/client"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// PHYSICAL INFRASTRUCTURE LAYER
// ==========================================

model Controller {
  id         String   @id @default(uuid())
  macAddress String   @unique // Unique identifier for the Raspberry Pi
  ipAddress  String
  name       String // e.g., "Tent 1 Pi", "Clone Rack Pi"
  status     String   @default("OFFLINE") // ONLINE, OFFLINE, ERROR
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  growCycles GrowCycle[] // A Pi can run sequential cycles over its lifetime
  sensors    Sensor[] // Sensors wired to this physical Pi hub
  devices    Device[] // Relays / hardware outputs wired to this physical Pi (persist across grows)
}

enum SensorType {
  HUMIDITY
  TEMPERATURE
  TEMP_HUMIDITY
  CO2
  PH
  EC
}

enum SensorProtocol {
  I2C
  SPI
  UART
  RS485
}

model Sensor {
  id           String         @id @default(uuid())
  controllerId String
  name         String
  type         SensorType
  mqttTopic    String         @default("") // Deprecated — topics are derived from sensor ID
  pinNumbers   Int[]
  protocol     SensorProtocol
  lastActive   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  controller Controller  @relation(fields: [controllerId], references: [id], onDelete: Cascade)
  telemetry  Telemetry[]
}

enum DeviceType {
  LIGHT
  EXHAUST_FAN
  INTAKE_FAN
  CIRCULATION_FAN
  WATER_PUMP
  AIR_CONDITIONER
  HEATER
  HUMIDIFIER
  DEHUMIDIFIER
  CO2_INJECTOR
}

// How a device is driven. Drives the automation engine:
//   MANUAL       — no automation; only REST / UI commands.
//   SCHEDULED    — driven by the day/night clock (used by LIGHT).
//   THRESHOLD    — evaluated against PhaseEnvironment rules (fans, heater, etc.).
//   ALWAYS_ON    — pinned ON for the duration of the active grow.
//   ALWAYS_OFF   — pinned OFF (override).
enum AutomationMode {
  MANUAL
  SCHEDULED
  THRESHOLD
  ALWAYS_ON
  ALWAYS_OFF
}

model Device {
  id             String         @id @default(uuid())
  controllerId   String
  name           String // e.g., "SpiderFarmer SF2000", "AC Infinity T6"
  type           DeviceType
  pinNumber      Int // GPIO pin or Relay channel on the Pi
  mqttTopic      String         @default("") // Deprecated — topics are derived from device ID
  automationMode AutomationMode @default(MANUAL)
  isActive       Boolean        @default(true)
  maxOnSeconds   Int?           // Maximum continuous ON time before the engine force-OFFs; null = unlimited
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  controller      Controller       @relation(fields: [controllerId], references: [id], onDelete: Cascade)
  deviceStateLogs DeviceStateLog[] // Audit trail of every ON/OFF command issued to this device
  automationRules AutomationRule[] // Rules that actuate this device
  thresholdHold   DeviceThresholdHold? // Active "threshold is asserting this device" hold; interval scheduler yields while fresh
}

// ==========================================
// LOGICAL GROW & CONFIGURATION LAYER
// ==========================================

model GrowCycle {
  id           String    @id @default(uuid())
  controllerId String // Links this specific grow cycle to a physical Pi
  name         String
  isActive     Boolean   @default(false)
  startAt      DateTime? @db.Date // Optional cycle-level start date (date only, no timestamp)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  controller      Controller       @relation(fields: [controllerId], references: [id])
  phases          GrowPhase[]
  telemetry       Telemetry[]
  automationRules AutomationRule[] // Cycle-scoped rules (e.g. ambient baseline)

  // Enforce at most ONE active grow per controller at any moment.
  // Finished/ended grows (isActive=false) do not participate in the constraint,
  // so the same physical Pi can run sequential grows over its lifetime.
  @@unique([controllerId], where: { isActive: true }, map: "one_active_grow_per_controller")
}

// Day/night period discriminator for per-phase thresholds and rules.
enum DayNightPeriod {
  DAY
  NIGHT
}

model GrowPhase {
  id                 String    @id @default(uuid())
  growCycleId        String
  name               String // e.g., "Vegetative", "Flower"
  order              Int // Execution order sequence
  durationDays       Int // Target days for this phase
  isActive           Boolean   @default(false)
  startAt            DateTime? @db.Date
  endAt              DateTime? @db.Date
  // Day/night schedule for this phase. Times are minutes-from-midnight (0..1440).
  // `dayStartMinutes` is when the photoperiod DAY begins each 24h cycle.
  // `dayDurationMinutes` is how long the day lasts; night = 1440 - dayDurationMinutes.
  // Examples: 18/6 => 360..1440; 12/12 => 360..720; all-day => 0..1440; all-night => 0..0.
  dayStartMinutes    Int       @default(360) // 06:00 by default
  dayDurationMinutes Int       @default(1080) // 18h day by default
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  growCycle        GrowCycle         @relation(fields: [growCycleId], references: [id], onDelete: Cascade)
  environments     PhaseEnvironment[] // Per-period (DAY/NIGHT) threshold sets
  automationRules  AutomationRule[] // Phase-scoped rules
}

// Per-phase, per-period environmental thresholds. Empty fields are
// considered "unconstrained" by the automation engine.
model PhaseEnvironment {
  id             String        @id @default(uuid())
  growPhaseId    String
  period         DayNightPeriod
  tempMin        Float?
  tempMax        Float?
  tempTarget     Float?
  humidityMin    Float?
  humidityMax    Float?
  humidityTarget Float?
  co2Min         Float?
  co2Max         Float?
  co2Target      Float?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  growPhase GrowPhase @relation(fields: [growPhaseId], references: [id], onDelete: Cascade)

  @@unique([growPhaseId, period], map: "one_env_per_phase_period")
}

// What a rule does. The six threshold conditions (ABOVE_MAX / BELOW_MIN /
// ABOVE_MIN / BELOW_MAX / ABOVE_TARGET / BELOW_TARGET) are evaluated by the
// threshold evaluator against the current PhaseEnvironment row for the
// watched sensor type. ALWAYS_ON / ALWAYS_OFF pin a device to a fixed state
// within the rule's scope (phase or cycle) and are enforced by the
// automation scheduler's 60s tick — they suppress any threshold rules for
// the same (device, scope, period).
// SCHEDULE_ON / SCHEDULE_OFF are retained for backward compatibility but are
// rejected at the API layer (no remaining consumer — light scheduling is
// driven directly by the grow-phase clock).
enum RuleCondition {
  ABOVE_MAX
  BELOW_MIN
  ABOVE_MIN
  BELOW_MAX
  ABOVE_TARGET
  BELOW_TARGET
  ALWAYS_ON
  ALWAYS_OFF
  INTERVAL
  SCHEDULE_ON
  SCHEDULE_OFF
}

enum DeviceAction {
  ON
  OFF
}

// Explicit per-device automation rule. Scoped to a phase (preferred) or a
// cycle (rare). Exactly one of growPhaseId / growCycleId must be set — enforced
// at the application layer.
model AutomationRule {
  id                String        @id @default(uuid())
  growCycleId       String?
  growPhaseId       String?
  deviceId          String
  watchedSensorType SensorType?
  period            DayNightPeriod? // null = applies to BOTH day and night
  condition         RuleCondition
  action            DeviceAction
  cooldownSeconds   Int           @default(180) // Min gap between two auto commands from this rule
  // INTERVAL-condition fields. For duty-cycle schedules (e.g. fan 30s ON every 5 min).
  // intervalOnSeconds is the ON pulse duration; intervalCycleSeconds is the total
  // cycle (ON + OFF). Required & valid only when condition = INTERVAL; null otherwise.
  intervalOnSeconds    Int?
  intervalCycleSeconds Int?
  enabled           Boolean       @default(true)
  lastTriggeredAt   DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  device    Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  growCycle GrowCycle? @relation(fields: [growCycleId], references: [id], onDelete: Cascade)
  growPhase GrowPhase? @relation(fields: [growPhaseId], references: [id], onDelete: Cascade)

  @@index([growCycleId])
  @@index([growPhaseId])
  @@index([deviceId])
  @@index([enabled])
}

model DeviceStateLog {
  id        String   @id @default(uuid())
  deviceId  String
  action    String   // "ON" | "OFF"  (matches the MQTT command payload)
  source    String   // "MANUAL" | "AUTO" | "UI" — who/what issued the command
  reason    String?  // Optional human-readable context (e.g. threshold name, config id)
  createdAt DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([createdAt])
}

// "Threshold is asserting this device" hold, written by the threshold evaluator
// (src/automation/evaluator.ts) on every fire with heldUntil = now + cooldownSeconds.
// The interval scheduler (src/automation/interval-scheduler.ts) fully suspends the
// device while this hold is fresh, so a threshold rule can override an interval
// schedule. ruleId is an audit field (no FK) so rule deletion doesn't cascade.
model DeviceThresholdHold {
  deviceId   String   @id
  heldUntil  DateTime
  ruleId     String?
  updatedAt  DateTime @updatedAt

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

// ==========================================
// TELEMETRY LAYER
// ==========================================

model Telemetry {
  id          String     @id @default(uuid())
  growCycleId String
  sensorId    String
  sensorType  SensorType
  value       Float
  createdAt   DateTime   @default(now())

  growCycle GrowCycle @relation(fields: [growCycleId], references: [id], onDelete: Cascade)
  sensor    Sensor    @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  @@index([growCycleId])
  @@index([sensorId])
  @@index([sensorType])
  @@index([createdAt])
  @@index([growCycleId, sensorType, createdAt])
}
