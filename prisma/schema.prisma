generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Cycles {
  id                      String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String              @db.VarChar(100)
  description             String              @db.VarChar(255)
  type                    CycleType
  start_date              DateTime            @db.Timestamp(6)
  end_date                DateTime            @db.Timestamp(6)
  plant_type              String              @db.VarChar(100)

  phases                  Phases[]
  lights                  Lights[]
  sensors                 Sensors[]

  @@map("cycles")  
}

model Phases {
  id                      String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String              @db.VarChar(100)
  description             String              @db.VarChar(255)
  type                    PhaseType
  start_date              DateTime            @db.Timestamp(6)
  end_date                DateTime            @db.Timestamp(6)
  cycle_id                String              @db.Uuid
  active                  Boolean             @db.Boolean

  phase_light_schedules   PhaseLightSchedules[]

  cycles                  Cycles              @relation(fields: [cycle_id], references: [id], onDelete: Cascade)
  

  @@map("phases")
}

model Lights {
  id                      String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String              @db.VarChar(100)
  description             String              @db.VarChar(255)
  cycle_id                String              @db.Uuid

  phase_light_schedules   PhaseLightSchedules[]

  cycles                  Cycles              @relation(fields: [cycle_id], references: [id], onDelete: Cascade)

  @@map("lights")
}

model Sensors {
  id                      String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String              @db.VarChar(100)
  description             String              @db.VarChar(255)
  cycle_id                String              @db.Uuid

  cycles                  Cycles              @relation(fields: [cycle_id], references: [id], onDelete: Cascade)

  @@map("sensors")
}

model PhaseLightSchedules {
  phase_id                String              @db.Uuid
  light_id                String              @db.Uuid
  trigger_on_time         DateTime            @db.Timestamp(6)
  trigger_off_time        DateTime            @db.Timestamp(6)

  phases                  Phases              @relation(fields: [phase_id], references: [id], onDelete: Cascade)
  lights                  Lights              @relation(fields: [light_id], references: [id], onDelete: Cascade)

  @@unique([phase_id, light_id])

  @@map("phase_light_schedules")
}

model Temperature {
  id                      String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sensor_id               String              @db.Uuid
  phase_id                String              @db.Uuid
  value                   Float               @db.DoublePrecision
  created_at              DateTime            
}




enum CycleType {
  GROW

  @@map("cycle_types")
}

enum PhaseType {
  PROPOGATION
  VEG
  FLOWER
  CURING

  @@map("phase_types")
}
