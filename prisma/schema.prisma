generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// PHYSICAL INFRASTRUCTURE LAYER
// ==========================================

model Controller {
  id          String      @id @default(uuid())
  macAddress  String      @unique // Unique identifier for the Raspberry Pi
  ipAddress   String      
  name        String      // e.g., "Tent 1 Pi", "Clone Rack Pi"
  status      String      @default("OFFLINE") // ONLINE, OFFLINE, ERROR
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  devices     Device[]
  growCycles  GrowCycle[] // A Pi can run multiple cycles over its lifetime
}

enum DeviceType {
  LIGHT
  EXHAUST_FAN
  INTAKE_FAN
  CIRCULATION_FAN
  WATER_PUMP
  AIR_CONDITIONER
  HEATER
  HUMIDIFIER
  DEHUMIDIFIER
  CO2_INJECTOR
}

model Device {
  id            String          @id @default(uuid())
  controllerId  String
  name          String          // e.g., "SpiderFarmer SF2000", "AC Infinity T6"
  type          DeviceType
  pinNumber     Int             // GPIO pin or Relay channel on the Pi
  mqttTopic     String          // e.g., "tent1/device/light/cmd"
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  controller    Controller      @relation(fields: [controllerId], references: [id], onDelete: Cascade)
  deviceConfigs DeviceConfig[]  // The specific settings for this device per phase
}

// ==========================================
// LOGICAL GROW & CONFIGURATION LAYER
// ==========================================

model GrowCycle {
  id           String      @id @default(uuid())
  controllerId String      // Links this specific grow cycle to a physical Pi
  name         String
  isActive     Boolean     @default(false)
  startAt      DateTime?   @db.Date // Optional cycle-level start date (date only, no timestamp)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  controller   Controller  @relation(fields: [controllerId], references: [id])
  phases       GrowPhase[]
  telemetry   Telemetry[]
}

model GrowPhase {
  id          String         @id @default(uuid())
  growCycleId String
  name        String         // e.g., "Vegetative", "Flower"
  order       Int            // Execution order sequence
  durationDays Int           // Target days for this phase
  isActive    Boolean        @default(false)
  startAt     DateTime?        @db.Date
  endAt       DateTime?        @db.Date
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  growCycle   GrowCycle      @relation(fields: [growCycleId], references: [id], onDelete: Cascade)
  deviceConfigs DeviceConfig[] // Specific device rules for this phase
}

// ==========================================
// TRIGGER & DEVICE CONFIGURATION LAYER
// ==========================================

enum TriggerType {
  SCHEDULE    // Time-based (e.g., Lights on 18/6)
  THRESHOLD   // Environment-based (e.g., Turn on AC if Temp > 26°C)
  ALWAYS_ON   // Continuous devices (e.g., Circulation fans)
  ALWAYS_OFF  // Safety overrides
}

model DeviceConfig {
  id          String      @id @default(uuid())
  growPhaseId String
  deviceId    String      // Which physical device this config rules over
  triggerType TriggerType
  
  // JSON payload stores specific parameters depending on TriggerType
  // Schedule Example:  {"onTime": "06:00", "offTime": "00:00"}
  // Threshold Example: {"sensor": "TEMPERATURE", "condition": "GREATER_THAN", "value": 26.5, "action": "ON"}
  configData  Json        
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  growPhase   GrowPhase   @relation(fields: [growPhaseId], references: [id], onDelete: Cascade)
  device      Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

// ==========================================
// TELEMETRY LAYER
// ==========================================

model Telemetry {
  id          String    @id @default(uuid())
  growCycleId String
  sensorType  String    // TEMPERATURE, HUMIDITY, CO2, PH, EC
  value       Float
  createdAt   DateTime  @default(now())

  growCycle   GrowCycle @relation(fields: [growCycleId], references: [id], onDelete: Cascade)
}
