{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "unicorn", "typescript", "oxc"],
  "categories": {
    "correctness": "deny",
    "suspicious": "warn",
    "pedantic": "warn",
    "perf": "warn",
    "style": "warn",
    "restriction": "off",
    "nursery": "warn"
  },
  "env": {
    "node": true
  },
  "rules": {
    "no-console": "off",
    "no-debugger": "error",
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-process-exit": "warn",
    "unicorn/no-null": "off"
  },
  "ignorePatterns": ["dist/", "node_modules/", "*.config.*"]
}
